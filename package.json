{
    "name": "pi-code",
    "version": "2.3.0",
    "description": "A curated pi package bundling custom extensions and configurations.",
    "keywords": [
        "pi-package"
    ],
    "license": "GPL-3.0-only",
    "type": "module",
    "dependencies": {
        "@tmustier/pi-files-widget": "*",
        "@ff-labs/fff-node": "*",
        "better-sqlite3": "^11.0.0",
        "sqlite-vec": "^0.1.9",
        "remark-parse": "^11.0.0",
        "mdast-util-from-markdown": "^2.0.0",
        "mdast-util-to-markdown": "^2.0.0",
        "@types/better-sqlite3": "^7.6.0",
        "@types/mdast": "^4.0.0"
    },
    "pi": {
        "extensions": [
            "./extensions",
            "node_modules/@tmustier/pi-files-widget/index.ts"
        ],
        "skills": [
            "./skills"
        ],
        "prompts": [
            "./prompts"
        ]
    },
    "bundleDependencies": [
        "@tmustier/pi-files-widget",
        "@ff-labs/fff-node",
        "better-sqlite3",
        "sqlite-vec",
        "remark-parse",
        "mdast-util-from-markdown",
        "mdast-util-to-markdown",
        "@types/better-sqlite3",
        "@types/mdast"
    ],
    "bundledDependencies": [
        "@tmustier/pi-files-widget",
        "@ff-labs/fff-node",
        "better-sqlite3",
        "sqlite-vec",
        "remark-parse",
        "mdast-util-from-markdown",
        "mdast-util-to-markdown",
        "@types/better-sqlite3",
        "@types/mdast"
    ],
    "overrides": {
        "basic-ftp": "6.0.1",
        "fast-uri": "3.1.2",
        "fast-xml-builder": "1.2.0",
        "fast-xml-parser": "5.7.3"
    },
    "devDependencies": {
        "typescript": "^6.0.3"
    }
}
