{
    "name": "pi-code",
    "version": "1.18.1",
    "description": "A curated pi package bundling custom extensions and configurations.",
    "keywords": [
        "pi-package"
    ],
    "license": "GPL-3.0-only",
    "type": "module",
    "dependencies": {
        "@aliou/pi-processes": "*"
    },
    "bundledDependencies": [
        "@aliou/pi-processes"
    ],
    "pi": {
        "extensions": [
            "./extensions",
            "node_modules/@aliou/pi-processes/src/index.ts"
        ],
        "skills": [
            "./skills",
            "node_modules/@aliou/pi-processes/skills/pi-processes"
        ],
        "prompts": [
            "./prompts"
        ]
    },
    "bundleDependencies": [
        "@aliou/pi-processes"
    ],
    "overrides": {
        "basic-ftp": "6.0.1",
        "fast-uri": "3.1.2",
        "fast-xml-builder": "1.2.0",
        "fast-xml-parser": "5.7.3"
    },
    "devDependencies": {
        "typescript": "^6.0.3"
    }
}
