{
    "name": "pi-code",
    "version": "1.15.0",
    "description": "A curated pi package bundling custom extensions and configurations.",
    "keywords": [
        "pi-package"
    ],
    "license": "GPL-3.0-only",
    "type": "module",
    "dependencies": {
        "@aliou/pi-processes": "*",
        "@eko24ive/pi-ask": "^0.9.0",
        "pi-mcporter": "^0.3.2"
    },
    "bundledDependencies": [
        "@aliou/pi-processes",
        "pi-mcporter",
        "@eko24ive/pi-ask"
    ],

    "pi": {
        "extensions": [
            "./extensions",
            "node_modules/pi-mcporter/dist/index.js",
            "node_modules/@eko24ive/pi-ask/src/index.ts",
            "node_modules/@aliou/pi-processes/src/index.ts"
        ],
        "skills": [
            "./skills",
            "node_modules/@aliou/pi-processes/skills/pi-processes",
            "node_modules/@eko24ive/pi-ask/skills"
        ],
        "prompts": [
            "./prompts"
        ]
    },
    "bundleDependencies": [
        "@aliou/pi-processes",
        "pi-mcporter",
        "@eko24ive/pi-ask"
    ],
    "overrides": {
        "basic-ftp": "6.0.1",
        "fast-uri": "3.1.2",
        "fast-xml-builder": "1.2.0",
        "fast-xml-parser": "5.7.3"
    }
}
