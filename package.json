{
    "name": "pi-code",
    "version": "1.13.0",
    "description": "A curated pi package bundling custom extensions and configurations.",
    "keywords": [
        "pi-package"
    ],
    "license": "GPL-3.0-only",
    "type": "module",
    "dependencies": {
        "@aliou/pi-processes": "*",
        "pi-ask-tool-extension": "*",
        "pi-mcporter": "*"
    },
    "bundledDependencies": [
        "@aliou/pi-processes",
        "pi-mcporter",
        "pi-ask-tool-extension"
    ],
    "peerDependencies": {
        "@mariozechner/pi-agent-core": "*",
        "@mariozechner/pi-ai": "*",
        "@mariozechner/pi-coding-agent": "*",
        "@sinclair/typebox": "*"
    },
    "pi": {
        "extensions": [
            "./extensions",
            "node_modules/pi-mcporter/dist/index.js",
            "node_modules/pi-ask-tool-extension/src/index.ts",
            "node_modules/@aliou/pi-processes/src/index.ts"
        ],
        "skills": [
            "./skills",
            "node_modules/@aliou/pi-processes/skills/pi-processes"
        ],
        "prompts": [
            "./prompts"
        ]
    }
}
