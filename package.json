{
    "name": "pi-code",
    "version": "2.3.0",
    "description": "A curated pi package bundling custom extensions and configurations.",
    "keywords": [
        "pi-package"
    ],
    "license": "GPL-3.0-only",
    "type": "module",
    "dependencies": {
        "@tmustier/pi-files-widget": "*",
        "@ff-labs/fff-node": "*"
    },
    "pi": {
        "extensions": [
            "./extensions",
            "node_modules/@tmustier/pi-files-widget/index.ts"
        ],
        "skills": [
            "./skills"
        ],
        "prompts": [
            "./prompts"
        ]
    },
    "bundleDependencies": [
        "@tmustier/pi-files-widget",
        "@ff-labs/fff-node"
    ],
    "overrides": {
        "basic-ftp": "6.0.1",
        "fast-uri": "3.1.2",
        "fast-xml-builder": "1.2.0",
        "fast-xml-parser": "5.7.3"
    },
    "devDependencies": {
        "typescript": "^6.0.3"
    }
}
